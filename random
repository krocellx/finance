“””
End-to-end example. Run this to see the workflow.

Workflow:

1. Provide historical daily returns for each strategy (aligned to same dates).
1. Generate ONE scenario set (10k paths x 1260 days) — reused across everything.
1. Define one or more stop rules.
1. Backtest each (strategy, rule) combination.
1. Compare results.
   “””

import numpy as np
import pandas as pd
from backtest import (
generate_scenarios,
NoStop,
TrailingStopRule,
run_backtest,
compare,
)

# —————————————————————————

# 1. Historical inputs (replace with your real data)

# —————————————————————————

dates = pd.bdate_range(“2006-01-01”, “2026-01-01”)
n_history = len(dates)
rng = np.random.default_rng(0)

# Synthetic returns with some autocorrelation so Politis-White returns

# something meaningful (rather than ~1 day on i.i.d. data).

def ar1_returns(n, mu, sigma, phi=0.05):
eps = rng.normal(0, sigma, n)
r = np.zeros(n)
for i in range(1, n):
r[i] = mu + phi * (r[i - 1] - mu) + eps[i]
return r

historical_returns = {
‘momentum’:    pd.Series(ar1_returns(n_history, 0.0006, 0.014, 0.10), index=dates),
‘mean_revert’: pd.Series(ar1_returns(n_history, 0.0004, 0.009, -0.05), index=dates),
‘vol_carry’:   pd.Series(ar1_returns(n_history, 0.0008, 0.020, 0.08),  index=dates),
}

# —————————————————————————

# 2. Generate scenarios ONCE — reuse for everything

# —————————————————————————

print(“Generating 10,000 scenarios…”)
scenarios = generate_scenarios(
historical_returns=historical_returns,
n_paths=10_000,
path_length=1260,    # 5 business years
L_mean=None,         # auto via Politis-White
seed=42,
)
print(f”  Block length used: L_mean = {scenarios[‘L_mean’]:.1f}”)
print(f”  Per-strategy Politis-White L: {scenarios[‘L_per_strategy’]}”)
print(f”  Index matrix shape: {scenarios[‘idx’].shape}”)

# —————————————————————————

# 3. Define stop rules

# —————————————————————————

INITIAL_CAPITAL = 10_000_000.0  # $10m starting equity per strategy

baseline = NoStop()

trailing_stop = TrailingStopRule(
levels=[
(400_000,  0.70),  # at $400k DD: cut 30% (run at 70%)
(1_100_000, 0.40), # at $1.1m DD: cut 60% (run at 40%)
(2_000_000, 0.00), # at $2m DD: full stop out
],
reentry_recovery=300_000,  # if recover $300k from trough, step back up
label=“Trailing-30/60/100-Reentry300k”,
)

# Easy to add variants for comparison:

trailing_no_reentry = TrailingStopRule(
levels=[
(400_000,  0.70),
(1_100_000, 0.40),
(2_000_000, 0.00),
],
reentry_recovery=0.0,
label=“Trailing-30/60/100-NoReentry”,
)

# —————————————————————————

# 4. Backtest every (strategy, rule) combination

# —————————————————————————

rules = [baseline, trailing_stop, trailing_no_reentry]
results = []
for strat_name, paths in scenarios[‘paths’].items():
for rule in rules:
print(f”  Backtesting {strat_name} x {rule.name}…”)
res = run_backtest(paths, rule, strat_name, INITIAL_CAPITAL)
results.append(res)

# —————————————————————————

# 5. Compare

# —————————————————————————

table = compare(results)
print(”\n” + “=” * 100)
print(“RESULTS”)
print(”=” * 100)
with pd.option_context(‘display.max_columns’, None, ‘display.width’, 200,
‘display.float_format’, ‘{:.4f}’.format):
print(table.to_string(index=False))

# Save for later analysis

table.to_csv(’/home/claude/backtest_results.csv’, index=False)
print(”\nSaved to /home/claude/backtest_results.csv”)

