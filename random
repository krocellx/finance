“””
Stationary Bootstrap (Politis-Romano 1994) for simulating return paths.

Workflow:

1. Pass in a list/array of historical dates.
1. Get back a matrix of bootstrapped date indices (n_paths x path_length).
1. Use that matrix to look up returns for any strategy:
   sim_returns = strategy_returns.values[index_matrix]
   This gives you 1000 simulated 5-year return paths for that strategy.

The same index_matrix can be reused across all 3 strategies, which keeps
the comparison clean (all strategies see the same simulated “market history”).
“””

import numpy as np
import pandas as pd
from arch.bootstrap import optimal_block_length

def politis_white_L(returns):
“””
Compute the Politis-White optimal mean block length for the
stationary bootstrap. Run on each strategy’s returns and take
the max (or median) across strategies as a starting point.
“””
opt = optimal_block_length(returns)
return float(opt[‘stationary’].iloc[0])

def stationary_bootstrap_indices(
n_history,
path_length,
n_paths,
L_mean,
seed=None,
):
“””
Generate a matrix of bootstrapped indices into the historical series.

```
Parameters
----------
n_history : int
    Number of days in your historical series (e.g., len(dates)).
path_length : int
    Days per simulated path. For 5 years of business days, use 1260.
n_paths : int
    Number of simulated paths (e.g., 1000 or 5000).
L_mean : float
    Target mean block length. Block lengths follow a geometric
    distribution with mean L_mean, so jump probability p = 1 / L_mean.
seed : int, optional
    Random seed for reproducibility.

Returns
-------
idx : np.ndarray of shape (n_paths, path_length), dtype int
    Each row is one simulated path of indices into the historical series.
    Use it to look up returns: returns_array[idx] -> simulated paths.
"""
rng = np.random.default_rng(seed)
p = 1.0 / L_mean

# Pre-draw all randomness for speed (vectorized).
# jumps[i, t] = True means: at day t of path i, jump to a new random start.
jumps = rng.random((n_paths, path_length)) < p
# Force a "jump" at t=0 so each path picks a random starting point.
jumps[:, 0] = True
# New starting points whenever we jump (we'll only use them where jumps is True).
new_starts = rng.integers(0, n_history, size=(n_paths, path_length))

idx = np.empty((n_paths, path_length), dtype=np.int64)

# Walk forward day-by-day. Hard to fully vectorize because each step
# depends on the previous, but this loop is over path_length (~1260),
# not n_paths, so it's fast.
current = new_starts[:, 0].copy()
idx[:, 0] = current
for t in range(1, path_length):
    # Where jumps[:,t] is True, take a fresh random start; else step forward.
    stepped = (current + 1) % n_history  # wraparound at end of history
    current = np.where(jumps[:, t], new_starts[:, t], stepped)
    idx[:, t] = current

return idx
```

def simulate_strategy_paths(strategy_returns, idx):
“””
Apply the bootstrap index matrix to a strategy’s return series.

```
Parameters
----------
strategy_returns : pd.Series or np.ndarray
    Daily returns for one strategy. Must be aligned to the same
    historical dates used to build `idx` (same length, same order).
idx : np.ndarray of shape (n_paths, path_length)
    Output of stationary_bootstrap_indices().

Returns
-------
paths : np.ndarray of shape (n_paths, path_length)
    Simulated daily return paths for this strategy.
"""
arr = np.asarray(strategy_returns)
if len(arr) != idx.max() + 1 and idx.max() >= len(arr):
    raise ValueError(
        f"idx references position {idx.max()} but strategy_returns "
        f"only has {len(arr)} entries. Make sure returns align with "
        f"the dates used to build idx."
    )
return arr[idx]
```

# —————————————————————————

# Example usage

# —————————————————————————

if **name** == “**main**”:
# —– Inputs you would provide —–
# A list of historical business dates (e.g., 20 years ~ 5040 days).
dates = pd.bdate_range(“2006-01-01”, “2026-01-01”)
n_history = len(dates)

```
# Three strategies' daily returns aligned to `dates`.
# Replace these with your real data.
rng_demo = np.random.default_rng(0)
strategy_A = pd.Series(rng_demo.normal(0.0005, 0.012, n_history), index=dates)
strategy_B = pd.Series(rng_demo.normal(0.0003, 0.008, n_history), index=dates)
strategy_C = pd.Series(rng_demo.normal(0.0007, 0.018, n_history), index=dates)

# ----- Step 1: pick L -----
# Run Politis-White on each strategy; take the max as a conservative default.
L_candidates = [
    politis_white_L(strategy_A),
    politis_white_L(strategy_B),
    politis_white_L(strategy_C),
]
print(f"Politis-White optimal L per strategy: {L_candidates}")
L_pw = max(L_candidates)
print(f"Using L_mean = {L_pw:.1f} (max across strategies)")

# For sensitivity analysis, you'd also run L = 20, 60, 120, 250.
L_sensitivity = [L_pw, 20, 60, 120, 250]

# ----- Step 2: build the bootstrap index matrix -----
# 5 years of business days = ~1260; 1000 paths.
# Use the SAME idx across all strategies for an apples-to-apples comparison.
idx = stationary_bootstrap_indices(
    n_history=n_history,
    path_length=1260,
    n_paths=1000,
    L_mean=L_pw,
    seed=42,
)
print(f"Index matrix shape: {idx.shape}")

# ----- Step 3: simulate each strategy -----
paths_A = simulate_strategy_paths(strategy_A, idx)
paths_B = simulate_strategy_paths(strategy_B, idx)
paths_C = simulate_strategy_paths(strategy_C, idx)
print(f"Strategy A paths shape: {paths_A.shape}")

# ----- Step 4: now you can apply your trailing-stop rule -----
# e.g., for each path, walk through the daily returns, track running
# equity curve, apply 30%/60%/100% cuts at $400k/$1.1m/$2m drawdowns,
# and record terminal wealth + max drawdown.

# Quick sanity check: terminal wealth distribution
terminal_A = (1 + paths_A).prod(axis=1)
print(f"\nStrategy A terminal wealth (no stops applied):")
print(f"  median: {np.median(terminal_A):.3f}")
print(f"  5th percentile: {np.percentile(terminal_A, 5):.3f}")
print(f"  95th percentile: {np.percentile(terminal_A, 95):.3f}")
